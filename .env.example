# 把這個檔案複製成 .env（去掉 .example），填入你的真實 key
# .env 已加入 .gitignore，不會上傳

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# FinMind API（有 token 可突破免費版 300次/小時限制）
FINMIND_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube Data API v3（用來搜尋頻道影片清單，可選；沒有就只能手動提供影片 ID）
# 申請：https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq Whisper API（個股語音密度轉錄，免費申請）
# 申請：https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
